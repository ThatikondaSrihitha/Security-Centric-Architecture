{
  "name": "E-Commerce System",
  "description": "A full-stack e-commerce platform with web and mobile clients, microservices backend, and external payment integration.",
  "components": [
    {
      "id": "c-customer",
      "name": "Customer",
      "type": "user",
      "description": "End-user accessing the e-commerce platform",
      "zone": "external",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-admin",
      "name": "Administrator",
      "type": "user",
      "description": "Internal administrator managing the platform",
      "zone": "internal",
      "internet_facing": true,
      "data_sensitivity": "high",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-webapp",
      "name": "Web Application",
      "type": "service",
      "description": "Frontend web application served to customers",
      "zone": "dmz",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-mobileapp",
      "name": "Mobile Application",
      "type": "service",
      "description": "Native mobile application for iOS and Android",
      "zone": "dmz",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-apigateway",
      "name": "API Gateway",
      "type": "api",
      "description": "Central API gateway routing requests to microservices",
      "zone": "dmz",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-authsvc",
      "name": "Authentication Service",
      "type": "service",
      "description": "Handles user authentication and token issuance",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-productsvc",
      "name": "Product Service",
      "type": "service",
      "description": "Manages product catalogue and inventory",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "low",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-ordersvc",
      "name": "Order Service",
      "type": "service",
      "description": "Manages customer orders and order lifecycle",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "high",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-paymentsvc",
      "name": "Payment Service",
      "type": "service",
      "description": "Processes payments and communicates with payment gateway",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-notificationsvc",
      "name": "Notification Service",
      "type": "service",
      "description": "Sends email/SMS notifications to customers",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "medium",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-customerdb",
      "name": "Customer Database",
      "type": "database",
      "description": "Stores customer PII, addresses, and credentials",
      "zone": "data",
      "internet_facing": false,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-productdb",
      "name": "Product Database",
      "type": "database",
      "description": "Stores product catalogue and inventory data",
      "zone": "data",
      "internet_facing": false,
      "data_sensitivity": "low",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-extpayment",
      "name": "External Payment Gateway",
      "type": "external",
      "description": "Third-party payment processor (e.g., Stripe, PayPal)",
      "zone": "external",
      "internet_facing": true,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    }
  ],
  "data_flows": [
    {
      "id": "df-001",
      "source": "Customer",
      "destination": "Web Application",
      "protocol": "HTTPS",
      "data": "Browse products, login credentials, checkout data",
      "encrypted": true,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-002",
      "source": "Customer",
      "destination": "Mobile Application",
      "protocol": "HTTPS",
      "data": "Mobile browsing, purchase requests",
      "encrypted": true,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-003",
      "source": "Web Application",
      "destination": "API Gateway",
      "protocol": "HTTPS",
      "data": "API requests from web client",
      "encrypted": true,
      "authenticated": true,
      "crosses_trust_boundary": false,
      "bidirectional": true
    },
    {
      "id": "df-004",
      "source": "Mobile Application",
      "destination": "API Gateway",
      "protocol": "HTTPS",
      "data": "API requests from mobile client",
      "encrypted": true,
      "authenticated": true,
      "crosses_trust_boundary": false,
      "bidirectional": true
    },
    {
      "id": "df-005",
      "source": "API Gateway",
      "destination": "Authentication Service",
      "protocol": "HTTP",
      "data": "Login credentials, token validation requests",
      "encrypted": false,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-006",
      "source": "API Gateway",
      "destination": "Product Service",
      "protocol": "HTTP",
      "data": "Product queries and catalogue requests",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-007",
      "source": "API Gateway",
      "destination": "Order Service",
      "protocol": "HTTP",
      "data": "Order creation, status updates",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-008",
      "source": "Order Service",
      "destination": "Payment Service",
      "protocol": "HTTP",
      "data": "Payment authorisation requests with card data",
      "encrypted": false,
      "authenticated": false,
      "crosses_trust_boundary": false,
      "bidirectional": true
    },
    {
      "id": "df-009",
      "source": "Payment Service",
      "destination": "External Payment Gateway",
      "protocol": "HTTPS",
      "data": "Payment processing, sensitive card information",
      "encrypted": true,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-010",
      "source": "Authentication Service",
      "destination": "Customer Database",
      "protocol": "SQL",
      "data": "Credential lookup, user profile data",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-011",
      "source": "Product Service",
      "destination": "Product Database",
      "protocol": "SQL",
      "data": "Product reads and inventory updates",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": false,
      "bidirectional": true
    },
    {
      "id": "df-012",
      "source": "Notification Service",
      "destination": "Customer",
      "protocol": "SMTP",
      "data": "Order confirmation, promotional emails",
      "encrypted": false,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": false
    },
    {
      "id": "df-013",
      "source": "Administrator",
      "destination": "Web Application",
      "protocol": "HTTPS",
      "data": "Administrative operations and configuration",
      "encrypted": true,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    }
  ],
  "trust_boundaries": [
    {
      "id": "tb-001",
      "name": "Internet / DMZ Boundary",
      "zone_from": "external",
      "zone_to": "dmz",
      "description": "Boundary between the public internet and the DMZ"
    },
    {
      "id": "tb-002",
      "name": "DMZ / Internal Boundary",
      "zone_from": "dmz",
      "zone_to": "internal",
      "description": "Boundary between DMZ and internal microservices"
    },
    {
      "id": "tb-003",
      "name": "Internal / Data Boundary",
      "zone_from": "internal",
      "zone_to": "data",
      "description": "Boundary between internal services and the data tier"
    },
    {
      "id": "tb-004",
      "name": "Internal / External Boundary",
      "zone_from": "internal",
      "zone_to": "external",
      "description": "Boundary for external third-party integrations"
    }
  ],
  "metadata": {
    "source_file": "sample_ecommerce.json",
    "version": "1.0"
  }
}
