{
  "name": "University Student Portal",
  "description": "A web-based student portal for managing courses, grades, fees, and library access with admin and faculty roles.",
  "components": [
    {
      "id": "c-student",
      "name": "Student",
      "type": "user",
      "description": "Student accessing the portal",
      "zone": "external",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-faculty",
      "name": "Faculty",
      "type": "user",
      "description": "Faculty member entering grades and managing courses",
      "zone": "internal",
      "internet_facing": true,
      "data_sensitivity": "high",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-admin",
      "name": "Administrator",
      "type": "user",
      "description": "System administrator managing users and configuration",
      "zone": "internal",
      "internet_facing": true,
      "data_sensitivity": "critical",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-webportal",
      "name": "Web Portal",
      "type": "service",
      "description": "Main web application served to all users",
      "zone": "dmz",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-apigateway",
      "name": "API Gateway",
      "type": "api",
      "description": "Routes requests to backend microservices",
      "zone": "dmz",
      "internet_facing": true,
      "data_sensitivity": "medium",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-authsvc",
      "name": "Auth Service",
      "type": "service",
      "description": "Handles login, session tokens, and password management",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": true,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-coursesvc",
      "name": "Course Service",
      "type": "service",
      "description": "Manages course registration and timetable",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "low",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": true,
      "rate_limiting": false,
      "input_validation": true
    },
    {
      "id": "c-gradesvc",
      "name": "Grade Service",
      "type": "service",
      "description": "Stores and serves student grade records",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "high",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-feesvc",
      "name": "Fee Payment Service",
      "type": "service",
      "description": "Handles tuition fee payments and receipts",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-studentdb",
      "name": "Student Database",
      "type": "database",
      "description": "Stores student PII, grades, enrollment, and fee records",
      "zone": "data",
      "internet_facing": false,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-paymentgw",
      "name": "External Payment Gateway",
      "type": "external",
      "description": "Third-party payment processor for fee collection",
      "zone": "external",
      "internet_facing": true,
      "data_sensitivity": "critical",
      "authentication": true,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    },
    {
      "id": "c-notif",
      "name": "Notification Service",
      "type": "service",
      "description": "Sends email and SMS alerts to students and faculty",
      "zone": "internal",
      "internet_facing": false,
      "data_sensitivity": "medium",
      "authentication": false,
      "authorization": false,
      "encryption_at_rest": false,
      "logging_enabled": false,
      "rate_limiting": false,
      "input_validation": false
    }
  ],
  "data_flows": [
    {
      "id": "df-001",
      "source": "Student",
      "destination": "Web Portal",
      "protocol": "HTTPS",
      "data": "Login credentials, course registration requests",
      "encrypted": true,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-002",
      "source": "Faculty",
      "destination": "Web Portal",
      "protocol": "HTTPS",
      "data": "Grade entry, course management",
      "encrypted": true,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-003",
      "source": "Administrator",
      "destination": "Web Portal",
      "protocol": "HTTPS",
      "data": "Admin operations, user management",
      "encrypted": true,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-004",
      "source": "Web Portal",
      "destination": "API Gateway",
      "protocol": "HTTP",
      "data": "All user requests forwarded to API",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": false,
      "bidirectional": true
    },
    {
      "id": "df-005",
      "source": "API Gateway",
      "destination": "Auth Service",
      "protocol": "HTTP",
      "data": "Token validation, login credentials",
      "encrypted": false,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-006",
      "source": "API Gateway",
      "destination": "Course Service",
      "protocol": "HTTP",
      "data": "Course registration and timetable queries",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-007",
      "source": "API Gateway",
      "destination": "Grade Service",
      "protocol": "HTTP",
      "data": "Grade queries and updates",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-008",
      "source": "API Gateway",
      "destination": "Fee Payment Service",
      "protocol": "HTTP",
      "data": "Fee payment requests with student financial data",
      "encrypted": false,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-009",
      "source": "Fee Payment Service",
      "destination": "External Payment Gateway",
      "protocol": "HTTPS",
      "data": "Payment details, card information",
      "encrypted": true,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-010",
      "source": "Auth Service",
      "destination": "Student Database",
      "protocol": "SQL",
      "data": "Credential lookups, session data",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-011",
      "source": "Grade Service",
      "destination": "Student Database",
      "protocol": "SQL",
      "data": "Grade records, student academic data",
      "encrypted": false,
      "authenticated": true,
      "crosses_trust_boundary": true,
      "bidirectional": true
    },
    {
      "id": "df-012",
      "source": "Notification Service",
      "destination": "Student",
      "protocol": "SMTP",
      "data": "Grade alerts, fee reminders, announcements",
      "encrypted": false,
      "authenticated": false,
      "crosses_trust_boundary": true,
      "bidirectional": false
    }
  ],
  "trust_boundaries": [
    {
      "id": "tb-001",
      "name": "Internet / DMZ Boundary",
      "zone_from": "external",
      "zone_to": "dmz",
      "description": "Public internet to portal DMZ"
    },
    {
      "id": "tb-002",
      "name": "DMZ / Internal Boundary",
      "zone_from": "dmz",
      "zone_to": "internal",
      "description": "Portal/API to internal services"
    },
    {
      "id": "tb-003",
      "name": "Internal / Data Boundary",
      "zone_from": "internal",
      "zone_to": "data",
      "description": "Services to database tier"
    },
    {
      "id": "tb-004",
      "name": "Internal / External Payment",
      "zone_from": "internal",
      "zone_to": "external",
      "description": "Internal fee service to external payment gateway"
    }
  ],
  "metadata": {
    "source_file": "sample_upload_test.json",
    "version": "1.0",
    "domain": "Education",
    "compliance": "FERPA, Data Protection Act"
  }
}
